generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerStatusType {
  PET_OWNER
  BREEDER
  RESCUE
  FOSTER
  PROFESSIONAL
}

enum RoleApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  WITHDRAWN
}

enum RequestedRole {
  BREEDER
  RESCUE
  FOSTER
  PROFESSIONAL
}

enum ProfessionalCategory {
  TRAINER
  GROOMER
  DOG_WALKER
  BEHAVIOURIST
  PHOTOGRAPHER
  VETERINARY_CARE
  OTHER
}

enum PromotionTier {
  NONE
  FEATURED
}

enum DogVisibility {
  PUBLIC
  PRIVATE
  LINK_ONLY
}

enum DogRecordCategory {
  IDENTITY
  DNA
  HEALTH
  CARE
  IDENTIFICATION
  INSURANCE
  PEDIGREE
  TITLES
  WORKING_QUALIFICATIONS
  TEMPERAMENT_TESTS
  BREEDING_APPROVALS
  OTHER
}

enum DogRecordStatus {
  HAVE_RECORD
  DO_NOT_HAVE
}

enum DogRecordVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  displayName  String
  username     String         @unique
  country      String
  over16       Boolean
  ownerStatuses OwnerStatus[]
  roleApplications RoleApplication[]
  reviewedRoleApplications RoleApplication[] @relation("RoleApplicationReviewer")
  dogOwnerships DogOwnership[]
  sessions     Session[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model OwnerStatus {
  id        String          @id @default(cuid())
  userId    String
  status    OwnerStatusType
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, status])
}

model RoleApplication {
  id                 String                @id @default(cuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedRole      RequestedRole
  status             RoleApplicationStatus @default(DRAFT)
  applicantType      String?
  organisationName   String?
  publicDisplayName  String?
  website            String?
  email              String?
  showEmailPublicly  Boolean               @default(false)
  phone              String?
  serviceArea        String?
  registrationNumber String?
  charityNumber      String?
  insuranceDetails   String?
  qualifications     String?
  professionalCategory ProfessionalCategory?
  breeds             String?
  description        String?
  evidenceNotes      String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedById       String?
  reviewedBy         User?                 @relation("RoleApplicationReviewer", fields: [reviewedById], references: [id])
  rejectionReason    String?
  isFeatured         Boolean               @default(false)
  featuredUntil      DateTime?
  promotionTier      PromotionTier         @default(NONE)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([userId])
  @@index([requestedRole])
  @@index([status])
  @@index([organisationName])
  @@index([requestedRole, status])
}

model DogIdentity {
  id                    String          @id @default(cuid())
  registryNumber        String          @unique
  registrySequence      Int             @unique @default(autoincrement())
  name                  String
  primaryRole           String
  kennelClubName        String?
  breed                 String?
  isMixedBreed          Boolean         @default(false)
  breedMix              String?
  dnaConfirmed          String?
  dogTypes              String?
  dateOfBirth           DateTime?
  estimatedDob          Boolean         @default(false)
  sex                   String?
  colour                String?
  countryOfRegistration String?
  visibility            DogVisibility   @default(PUBLIC)
  ownerships            DogOwnership[]
  records               DogRecord[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model DogRecord {
  id                 String                      @id @default(cuid())
  dogId              String
  dog                DogIdentity                 @relation(fields: [dogId], references: [id], onDelete: Cascade)
  category           DogRecordCategory
  recordType         String
  provider           String?
  status             DogRecordStatus             @default(HAVE_RECORD)
  verificationStatus DogRecordVerificationStatus @default(NOT_SUBMITTED)
  referenceNumber    String?
  issueDate          DateTime?
  expiryDate         DateTime?
  notes              String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([dogId, category])
  @@index([dogId, verificationStatus])
  @@index([category, recordType])
  @@index([provider])
}

model DogOwnership {
  id        String      @id @default(cuid())
  userId    String
  dogId     String
  role      String      @default("OWNER")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog       DogIdentity @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, dogId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
