generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerStatusType {
  PET_OWNER
  BREEDER
  RESCUE
  FOSTER
  PROFESSIONAL
}

enum DogVisibility {
  PUBLIC
  PRIVATE
  LINK_ONLY
}

enum DogRecordCategory {
  IDENTITY
  DNA
  HEALTH
  CARE
  IDENTIFICATION
  INSURANCE
  PEDIGREE
  TITLES
  WORKING_QUALIFICATIONS
  TEMPERAMENT_TESTS
  BREEDING_APPROVALS
  OTHER
}

enum DogRecordStatus {
  HAVE_RECORD
  DO_NOT_HAVE
}

enum DogRecordVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  displayName  String
  username     String         @unique
  country      String
  over16       Boolean
  ownerStatuses OwnerStatus[]
  dogOwnerships DogOwnership[]
  sessions     Session[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model OwnerStatus {
  id        String          @id @default(cuid())
  userId    String
  status    OwnerStatusType
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, status])
}

model DogIdentity {
  id                    String          @id @default(cuid())
  registryNumber        String          @unique
  registrySequence      Int             @unique @default(autoincrement())
  name                  String
  primaryRole           String
  kennelClubName        String?
  breed                 String?
  isMixedBreed          Boolean         @default(false)
  breedMix              String?
  dnaConfirmed          String?
  dogTypes              String?
  dateOfBirth           DateTime?
  estimatedDob          Boolean         @default(false)
  sex                   String?
  colour                String?
  countryOfRegistration String?
  visibility            DogVisibility   @default(PUBLIC)
  ownerships            DogOwnership[]
  records               DogRecord[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model DogRecord {
  id                 String                      @id @default(cuid())
  dogId              String
  dog                DogIdentity                 @relation(fields: [dogId], references: [id], onDelete: Cascade)
  category           DogRecordCategory
  recordType         String
  provider           String?
  status             DogRecordStatus             @default(HAVE_RECORD)
  verificationStatus DogRecordVerificationStatus @default(NOT_SUBMITTED)
  referenceNumber    String?
  issueDate          DateTime?
  expiryDate         DateTime?
  notes              String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([dogId, category])
  @@index([dogId, verificationStatus])
  @@index([category, recordType])
  @@index([provider])
}

model DogOwnership {
  id        String      @id @default(cuid())
  userId    String
  dogId     String
  role      String      @default("OWNER")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog       DogIdentity @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, dogId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
