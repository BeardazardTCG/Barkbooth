generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerStatusType {
  PET_OWNER
  BREEDER
  RESCUE
  FOSTER
  PROFESSIONAL
}

enum RoleApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  WITHDRAWN
}

enum RequestedRole {
  BREEDER
  RESCUE
  FOSTER
  PROFESSIONAL
}

enum ProfessionalCategory {
  TRAINER
  GROOMER
  DOG_WALKER
  BEHAVIOURIST
  PHOTOGRAPHER
  VETERINARY_CARE
  OTHER
}

enum PromotionTier {
  NONE
  FEATURED
}

enum DogVisibility {
  PUBLIC
  PRIVATE
  LINK_ONLY
}

enum DogAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REVOKED
}

enum DogRelationshipType {
  CO_OWNER
  KEEPER
  CONTRACT_HOLDER
  FOSTER
  RESCUE
  BREEDER
  VETERINARY
  GROOMER
  TRAINER
  SITTER
  OTHER_PROFESSIONAL
}

enum DogAccessLevel {
  VIEW
  CONTRIBUTE
  MANAGE
}

enum DogRecordCategory {
  IDENTITY
  DNA
  HEALTH
  CARE
  IDENTIFICATION
  INSURANCE
  PEDIGREE
  TITLES
  WORKING_QUALIFICATIONS
  ACTIVITIES_WORK
  TEMPERAMENT_TESTS
  BREEDING_APPROVALS
  OTHER
}

enum DogRecordStatus {
  HAVE_RECORD
  DO_NOT_HAVE
}

enum DogRecordVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum BehaviourAnswer {
  YES
  NO
  UNKNOWN
}

enum BehaviourAssessmentSource {
  OWNER_DECLARED
  VERIFIED_RESCUE_ASSESSED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  displayName  String
  username     String         @unique
  country      String
  over16       Boolean
  ownerStatuses OwnerStatus[]
  roleApplications RoleApplication[]
  reviewedRoleApplications RoleApplication[] @relation("RoleApplicationReviewer")
  dogOwnerships DogOwnership[]
  requestedDogAccess DogAccessRequest[] @relation("DogAccessRequester")
  incomingDogAccess DogAccessRequest[] @relation("DogAccessTargetOwner")
  reviewedDogAccess DogAccessRequest[] @relation("DogAccessReviewer")
  revokedDogAccess DogAccessRequest[] @relation("DogAccessRevoker")
  uploadedDogPhotos DogProfilePhoto[]
  uploadedRecordDocuments DogRecordDocument[]
  sessions     Session[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model OwnerStatus {
  id        String          @id @default(cuid())
  userId    String
  status    OwnerStatusType
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, status])
}

model RoleApplication {
  id                 String                @id @default(cuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedRole      RequestedRole
  status             RoleApplicationStatus @default(DRAFT)
  applicantType      String?
  organisationName   String?
  publicDisplayName  String?
  website            String?
  email              String?
  showEmailPublicly  Boolean               @default(false)
  phone              String?
  serviceArea        String?
  registrationNumber String?
  charityNumber      String?
  insuranceDetails   String?
  qualifications     String?
  professionalCategory ProfessionalCategory?
  breeds             String?
  description        String?
  evidenceNotes      String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedById       String?
  reviewedBy         User?                 @relation("RoleApplicationReviewer", fields: [reviewedById], references: [id])
  rejectionReason    String?
  isFeatured         Boolean               @default(false)
  featuredUntil      DateTime?
  promotionTier      PromotionTier         @default(NONE)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([userId])
  @@index([requestedRole])
  @@index([status])
  @@index([organisationName])
  @@index([requestedRole, status])
}

model DogIdentity {
  id                    String          @id @default(cuid())
  registryNumber        String          @unique
  registrySequence      Int             @unique @default(autoincrement())
  name                  String
  primaryRole           String
  kennelClubName        String?
  breed                 String?
  isMixedBreed          Boolean         @default(false)
  breedMix              String?
  dnaConfirmed          String?
  dogTypes              String?
  neuteredSpayed        String?
  dateOfBirth           DateTime?
  estimatedDob          Boolean         @default(false)
  sex                   String?
  colour                String?
  countryOfRegistration String?
  visibility            DogVisibility   @default(PUBLIC)
  ownerships            DogOwnership[]
  accessRequests        DogAccessRequest[]
  records               DogRecord[]
  profilePhoto          DogProfilePhoto?
  behaviourLifestyle    DogBehaviourLifestyle?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model DogBehaviourLifestyle {
  id                  String                    @id @default(cuid())
  dogId               String                    @unique
  dog                 DogIdentity               @relation(fields: [dogId], references: [id], onDelete: Cascade)
  assessmentSource    BehaviourAssessmentSource @default(OWNER_DECLARED)
  reactive            BehaviourAnswer           @default(UNKNOWN)
  foodAggression      BehaviourAnswer           @default(UNKNOWN)
  resourceGuarding    BehaviourAnswer           @default(UNKNOWN)
  separationAnxiety   BehaviourAnswer           @default(UNKNOWN)
  highPreyDrive       BehaviourAnswer           @default(UNKNOWN)
  escapeArtist        BehaviourAnswer           @default(UNKNOWN)
  goodWithChildren    BehaviourAnswer           @default(UNKNOWN)
  goodWithDogs        BehaviourAnswer           @default(UNKNOWN)
  goodWithCats        BehaviourAnswer           @default(UNKNOWN)
  goodWithLivestock   BehaviourAnswer           @default(UNKNOWN)
  friendlyWithStrangers BehaviourAnswer         @default(UNKNOWN)
  reliableOffLead     BehaviourAnswer           @default(UNKNOWN)
  recallTrained       BehaviourAnswer           @default(UNKNOWN)
  crateTrained        BehaviourAnswer           @default(UNKNOWN)
  muzzleTrained       BehaviourAnswer           @default(UNKNOWN)
  neuteredSpayed      BehaviourAnswer           @default(UNKNOWN)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([assessmentSource])
}

model DogRecord {
  id                 String                      @id @default(cuid())
  dogId              String
  dog                DogIdentity                 @relation(fields: [dogId], references: [id], onDelete: Cascade)
  category           DogRecordCategory
  recordType         String
  provider           String?
  status             DogRecordStatus             @default(HAVE_RECORD)
  verificationStatus DogRecordVerificationStatus @default(NOT_SUBMITTED)
  referenceNumber    String?
  issueDate          DateTime?
  expiryDate         DateTime?
  notes              String?
  documents          DogRecordDocument[]
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([dogId, category])
  @@index([dogId, verificationStatus])
  @@index([category, recordType])
  @@index([provider])
}

model DogProfilePhoto {
  id           String      @id @default(cuid())
  dogId        String      @unique
  dog          DogIdentity @relation(fields: [dogId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  storageKey   String      @unique
  fileName     String
  contentType  String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([uploadedById])
}

model DogRecordDocument {
  id           String    @id @default(cuid())
  recordId     String
  record       DogRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  storageKey   String    @unique
  fileName     String
  contentType  String
  sizeBytes    Int
  createdAt    DateTime  @default(now())

  @@index([recordId])
  @@index([uploadedById])
}

model DogOwnership {
  id        String      @id @default(cuid())
  userId    String
  dogId     String
  role      String      @default("OWNER")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog       DogIdentity @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, dogId])
}

model DogAccessRequest {
  id                    String                 @id @default(cuid())
  dogId                 String
  dog                   DogIdentity            @relation(fields: [dogId], references: [id], onDelete: Cascade)
  requesterUserId       String
  requester             User                   @relation("DogAccessRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  targetOwnerUserId     String
  targetOwner           User                   @relation("DogAccessTargetOwner", fields: [targetOwnerUserId], references: [id], onDelete: Cascade)
  requestedRelationship DogRelationshipType
  requestedAccessLevel  DogAccessLevel         @default(VIEW)
  status                DogAccessRequestStatus @default(PENDING)
  message               String?
  reviewedAt            DateTime?
  reviewedById          String?
  reviewedBy            User?                  @relation("DogAccessReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  revokedAt             DateTime?
  revokedById           String?
  revokedBy             User?                  @relation("DogAccessRevoker", fields: [revokedById], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([dogId, status])
  @@index([requesterUserId, status])
  @@index([targetOwnerUserId, status])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
